# Sphinx HTML / cache output
build/

# Python bytecode
__pycache__/
*.pyc

# Generated by the build-finished hook in conf.py
source/llms-full.txt

# Generated by the Makefile `rst` target (sphinx-apidoc + writeversion)
source/version
source/reference/htmd*.rst
source/reference/modules.rst

# Notebook copies brought in by the Makefile `tutorials` target (sources live in ../tutorials/)
source/tutorials/adaptive/*.ipynb
source/tutorials/analysis/*.ipynb
source/how-to/*.ipynb

# Image folders copied alongside the notebook copies
source/tutorials/adaptive/img/
source/tutorials/analysis/img/
source/tutorials/system-prep/img/
source/how-to/img/
source/how-to/wrapping_img/

# Jupyter notebook execution checkpoints
**/.ipynb_checkpoints/
