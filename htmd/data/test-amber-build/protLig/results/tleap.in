# tleap file generated by amber.build
source ff0_leaprc.protein.ff14SB
source ff1_leaprc.lipid21
source ff2_leaprc.gaff2
source ff3_leaprc.RNA.Shaw
source ff4_leaprc.DNA.bsc1
source ff5_leaprc.water.tip3p

# Loading topologies
addAtomTypes {
    { "ca"  "C" "sp3" }
    { "ha"  "H" "sp3" }
    { "za"  "C" "sp3" }
    { "zb"  "C" "sp3" }
    { "zc"  "C" "sp3" }
    { "zd"  "H" "sp3" }
    { "ze"  "N" "sp3" }
}
BEN = loadmol2 topo0_BEN.mol2
set BEN.1.C0 element "C"
set BEN.1.C1 element "C"
set BEN.1.C2 element "C"
set BEN.1.C3 element "C"
set BEN.1.C4 element "C"
set BEN.1.C5 element "C"
set BEN.1.C6 element "C"
set BEN.1.N7 element "N"
set BEN.1.N8 element "N"
set BEN.1.H9 element "H"
set BEN.1.H10 element "H"
set BEN.1.H11 element "H"
set BEN.1.H12 element "H"
set BEN.1.H13 element "H"
set BEN.1.H14 element "H"
set BEN.1.H15 element "H"
set BEN.1.H16 element "H"
set BEN.1.H17 element "H"

# Loading parameter files
loadamberparams param0_BEN.frcmod

# Loading the system
mol = loadpdb input.pdb

# Adding disulfide bonds
bond mol.8.SG mol.138.SG
bond mol.26.SG mol.42.SG
bond mol.110.SG mol.211.SG
bond mol.117.SG mol.184.SG
bond mol.149.SG mol.163.SG
bond mol.174.SG mol.198.SG

setBox mol "vdw"

# Writing out the results
saveamberparm mol structure.prmtop structure.crd
quit