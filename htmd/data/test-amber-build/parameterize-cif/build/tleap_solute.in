# tleap file generated by amber.build
source ff0_leaprc.protein.ff14SB
source ff1_leaprc.lipid21
source ff2_leaprc.gaff2
source ff3_leaprc.RNA.Shaw
source ff4_leaprc.DNA.bsc1
source ff5_leaprc.water.tip3p

# Loading topologies
addAtomTypes {
    { "za"  "C" "sp3" }
    { "zb"  "C" "sp3" }
    { "zc"  "C" "sp3" }
    { "zd"  "C" "sp3" }
    { "ze"  "C" "sp3" }
    { "zf"  "C" "sp3" }
    { "zg"  "N" "sp3" }
    { "zh"  "N" "sp3" }
    { "zi"  "H" "sp3" }
    { "zj"  "H" "sp3" }
    { "zk"  "H" "sp3" }
    { "zl"  "H" "sp3" }
    { "zm"  "H" "sp3" }
    { "zn"  "H" "sp3" }
    { "zo"  "H" "sp3" }
}
MOL = loadmol2 topo0_MOL-orig.mol2
set MOL.1.C1 element "C"
set MOL.1.C2 element "C"
set MOL.1.C3 element "C"
set MOL.1.C4 element "C"
set MOL.1.C5 element "C"
set MOL.1.C6 element "C"
set MOL.1.C7 element "C"
set MOL.1.N1 element "N"
set MOL.1.N2 element "N"
set MOL.1.H1 element "H"
set MOL.1.H2 element "H"
set MOL.1.H3 element "H"
set MOL.1.H4 element "H"
set MOL.1.H5 element "H"
set MOL.1.H6 element "H"
set MOL.1.H7 element "H"
set MOL.1.H8 element "H"

# Loading parameter files
loadamberparams param0_MOL.frcmod

# Loading the system
mol = loadpdb input.pdb

# Adding disulfide bonds
bond mol.8.SG mol.138.SG
bond mol.26.SG mol.42.SG
bond mol.110.SG mol.211.SG
bond mol.117.SG mol.184.SG
bond mol.149.SG mol.163.SG
bond mol.174.SG mol.198.SG

setBox mol "vdw"

# Writing out the results
saveamberparm mol solute_charge.prmtop solute_charge.crd
quit